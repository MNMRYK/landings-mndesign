    margin-top: 20px;
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    border: 1px solid transparent;
    transition: all 0.3s;
    display: inline-block;
    box-shadow: 0 10px 25px #7e57c266;
  }

  .btn-primary:hover {
    color: #7e57c2;
    background-color: #fcfbff;
    border: 1px solid #7e57c277;
    transform: translateY(-2px);
  }

  .btn-secondary {
    color: #7e57c2;
    background-color: #fcfbff;
    border: 1px solid #7e57c277;
    border-radius: 8px;
    margin-top: 20px;
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s;
    display: inline-block;
    box-shadow: 0 10px 25px #7e57c266;
  }

  .btn-secondary:hover {
    color: #fff;
    background-color: var(--dark-violet);
    transform: translateY(-2px);
  }

  /* Contenedor padre de los visuals */
  .hero-visuals {
    position: relative;
    width: 100%;
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* El Mac (fondo) */
  .mac-mockup {
    position: absolute;
    width: 125%;
    z-index: 1;
    transition: transform 0.3s ease;
  }

  .mac-mockup img {
    width: 100%;
    height: auto;
    border-radius: 12px; /* Ajusta según tu imagen */
  }

  /* El iPhone (encima) */
  .mobile-mockup {
    position: absolute;
    bottom: 20px; /* Sale un poco por abajo del Mac */
    left: -40px; /* Desplazado a la derecha */
    width: 30%; /* Tamaño pequeño comparado con el Mac */
    z-index: 2;

    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .mobile-mockup img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Efecto suave al pasar el ratón */
  .mac-mockup:hover {
    transform: scale(1.02);
  }
  .mobile-mockup:hover {
    transform: translateY(-10px);
  }

  /* ==========================================
     INTERACCIONES
  ========================================== */
  .features-section {
    padding: 80px 0 0;
  }

  .section-title {
    text-align: center;
    font-size: 2.25rem;
    font-weight: bold;
    margin-bottom: 64px;
  }

  .feature-row {
    display: grid;
    grid-template-columns: 1fr 1fr; /* ¡Las dos columnas! */
    gap: 48px;
    align-items: center;
  }

  .feature-row.reverse {
    padding-top: 30px;
  }

  .feature-row.planner {
    padding-top: 50px;
    padding-bottom: 80px;
  }

  .feature-text h3 {
    font-size: 1.9rem;
    margin-bottom: 16px;
  }
  .feature-text p {
    color: var(--slate-600);
    font-size: 1.2rem;
    margin-bottom: 24px;
    font-weight: bold;
  }
  .feature-list {
    list-style: none;
  }

  .feature-list li {
    display: flex;
    align-items: center;
    margin-bottom: 16px;
    color: var(--slate-600);
    font-size: 1.1rem;
    font-weight: 500;
  }
  .feature-list .check {
    background-color: var(--white-iris);
    color: var(--dark-violet);
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-right: 12px;
    font-size: 0.9rem;
    font-weight: bold;
  }

  /* Mockups internos (Chat y RSVP) */
  .chat-mockup,
  .rsvp-mockup {
    background-color: var(--white);
    border: 1px solid var(--border-color);
    border-radius: 24px;
    padding: 24px;
    box-shadow: 0 20px 25px -5px rgba(26, 16, 45, 0.05); /* Sombra basada en eggplant */
    max-width: 350px;
    margin: 0 auto;
    position: relative;
  }

  .chat-header {
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 16px;
    margin-bottom: 24px;
  }
  .avatar {
    width: 40px;
    height: 40px;
    /* Eliminamos el color plano */
    /* background-color: var(--iris-glaze); */

    /* Añadimos la imagen */
    background-image: url("/avatar-familia.webp");
    background-size: cover; /* Asegura que la foto cubra todo el círculo */
    background-position: center; /* Centra la cara de la familia */
    border-radius: 50%;

    /* Opcional: un pequeño borde para que quede más integrado */
    border: 1px solid rgba(0, 0, 0, 0.1);
  }

  .chat-name {
    font-weight: bold;
    font-size: 0.875rem;
    color: var(--deep-eggplant);
  }

  .chat-status {
    font-size: 0.75rem;
    color: var(--slate-600);
  }

  .chat-bubble {
    padding: 16px;
    border-radius: 16px;
    font-size: 0.875rem;
    margin-bottom: 16px;
  }

  .chat-sent {
    background-color: #ddf8d8;
    margin-left: 32px;
    border-top-right-radius: 0;
    color: var(--deep-eggplant);
  }

  .chat-sent a {
    color: var(--electric-violet);
    font-weight: bold;
    display: block;
    margin-top: 8px;
  }

  .chat-received {
    background-color: var(--white);
    border: 1px solid var(--border-color);
    margin-right: 32px;
    border-top-left-radius: 0;
  }

  .notification-badge {
    position: absolute;
    top: -16px;
    right: -16px;
    background-color: var(--electric-violet);
    color: var(--white);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 1.2rem;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
  }

  .rsvp-mockup h4 {
    margin-bottom: 24px;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 8px;
    color: var(--deep-eggplant);
  }

  .form-group-mockup {
    margin-bottom: 16px;
  }

  .form-group-mockup label {
    display: block;
    font-size: 0.75rem;
    color: var(--slate-600);
    text-transform: uppercase;
    margin-bottom: 4px;
    font-weight: bold;
  }

  .input-mockup {
    height: 40px;
    background-color: var(--fondo-claro);
    border: 1px solid var(--border-color);
    border-radius: 8px;
  }

  .btn-mockup-outline {
    height: 48px;
    border: 2px dashed var(--electric-violet);
    background-color: var(--white-iris);
    color: var(--dark-violet);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-weight: bold;
    margin-top: 24px;
  }

  /* Mockup de Navegador Mac (Fila 3) */
  .browser-mockup {
    background-color: var(--white);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden; /* Corta lo que sobresale para mantener las esquinas redondas */
    box-shadow: 0 20px 25px -5px rgba(26, 16, 45, 0.08);
    max-width: 550px;
    max-height: 350px;
    margin: 0 auto;
    position: relative;
  }

  .browser-header {
    background-color: #1a1525; /* Tono oscuro muy elegante para la barra */
    padding: 12px 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .browser-dots {
    display: flex;
    gap: 6px;
    position: absolute;
    left: 16px;
  }

  .browser-dots span {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    display: inline-block;
  }

  .dot-red {
    background-color: #ff5f56;
  }
  .dot-yellow {
    background-color: #ffbd2e;
  }
  .dot-green {
    background-color: #27c93f;
  }

  .browser-url {
    background-color: rgba(255, 255, 255, 0.1);
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.75rem;
    padding: 4px 20px;
    border-radius: 20px;
    font-family: monospace;
    letter-spacing: 0.5px;
  }

  .browser-body {
    position: relative;
  }

  .mockup-img-browser {
    width: 100%;
    height: auto; /* Dejamos que la foto dicte su propia altura */
    display: block;
    object-fit: cover;
    border-bottom-left-radius: 12px;
    border-bottom-right-radius: 12px;
  }

  /* ==========================================
   QUE INCLUYEN LAS INVITACIONES
========================================== */
  .invitaciones-section {
    padding: 80px 20px 100px;
    background-color: var(--fondo-claro); /* Tono arena claro */
  
    text-align: center;
  }

  .invitaciones-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .invitaciones-title {
    font-family: "Montserrat", sans-serif;
    text-align: center;
    font-size: 2.25rem;
    font-weight: bold;
    color: #1a2530; /* Azul oscuro midnight */
    margin-bottom: 70px;
    font-weight: 400;
    letter-spacing: 0.05em;
  }

  /* El truco principal: CSS Grid automático */
  .invitaciones-grid {
    display: grid;
    /* Esto crea columnas que se adaptan solas. Mínimo 280px, máximo lo que sobre */
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px 30px; /* 50px de fila, 30px de columna */
  }

  .invitaciones-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 20px 20px;
    background-color: #ffffff; /* Fondo blanco para la tarjeta */
    border: 1px solid rgba(160, 88, 255, 0.05); /* Borde súper sutil */
    border-radius: 16px; /* Bordes redondeados elegantes */
    box-shadow: 0 10px 30px #7e57c266; /* Sombra base muy suave */
    transition: all 0.4s ease;
  }

  .invitaciones-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(160, 88, 255, 0.05); /* La sombra se vuelve dorada al pasar el ratón */
    border-color: rgba(160, 88, 255, 0.05); /* El borde se tiñe de dorado */
  }

  .invitaciones-icon {
    font-size: 1.8rem;
    color: #8d37d4;
    background-color: #f9efff8a; /* Fondo arena para el círculo del icono */
    width: 80px; /* Ancho y alto fijos para hacer un círculo perfecto */
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%; /* Esto lo convierte en círculo */
    margin-bottom: 25px;
    border: 1px solid rgba(160, 88, 255, 0.05);
    transition: all 0.4s ease;
  }

  /* Magia extra: el icono reacciona cuando pasas el ratón por la tarjeta completa */
  .invitaciones-card:hover .invitaciones-icon {
    background-color: #7e57c266;
    color: #ffffff;
    transform: scale(1.1);
  }

  .invitaciones-card h3 {
    font-family: "Montserrat", sans-serif;
    font-size: 1.2rem;
    color: #1a2530;
    margin-bottom: 15px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .invitaciones-card p {
    font-family: "nunito", sans-serif;
    font-size: 1.1rem;
    color: #1a2530;
    line-height: 1.7;
    font-weight: 600;
  }

  /* ==========================================
   SECCIÓN DE PLANES Y PRECIOS
========================================== */
  .pricing-section {
    padding: 80px 0 50px;
    background-color: #fcfbff;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    align-items: center; /* Alinea los elementos en el centro verticalmente */
    max-width: 1200px;
    margin: 0 auto;
  }

  .pricing-card {
    background-color: var(--white, #ffffff);
    border: 1px solid var(--border-color, #e2e8f0);
    border-radius: 24px;
    padding: 30px 20px; /* Reducimos el padding (antes 40px 30px) */
    box-shadow: 0 10px 30px rgba(26, 16, 45, 0.03);
    position: relative;
    transition:
      transform 0.4s ease,
      box-shadow 0.4s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .pricing-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(26, 16, 45, 0.08);
  }

  /* El truco para destacar la tarjeta del medio */
  .pricing-card.popular {
    border: 2px solid var(--electric-violet, #8d37d4);
    box-shadow: 0 20px 40px rgba(141, 55, 212, 0.15);
    transform: scale(1.05); /* La hacemos un 5% más grande que las demás */
    z-index: 2; /* Nos aseguramos de que se superponga visualmente a las otras */
  }

  .pricing-card.popular:hover {
    transform: scale(1.05) translateY(-8px);
  }

  .popular-badge {
    position: absolute;
    top: -16px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--electric-violet, #8d37d4);
    color: var(--white, #ffffff);
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: bold;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .plan-name {
    font-size: 1.5rem;
    color: var(--deep-eggplant, #1a2530);
    margin-bottom: 10px;
    text-align: center;
  }

  .plan-price {
    font-size: 2.5rem; /* Letra un poco más pequeña (antes 3rem) */
    font-weight: bold;
    color: var(--deep-eggplant, #1a2530);
    text-align: center;
    margin-bottom: 5px; /* Menos espacio debajo */
  }

  .plan-price span {
    font-size: 1rem;
    color: var(--slate-600, #4a5568);
    font-weight: normal;
    display: block;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: -5px;
  }

  .plan-desc {
    font-size: 1.1rem; /* Letra ligeramente más ajustada */
    color: var(--slate-600, #4a5568);
    text-align: center;
    line-height: 1.5;
    margin-bottom: 10px;
    padding-bottom: 15px; /* Menos espacio de separación con la línea */
    border-bottom: 1px solid var(--border-color, #e2e8f0);
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin-top: 10px;
    margin-bottom: 15px;
    flex-grow: 1; /* Esto empuja el botón siempre hacia abajo del todo */
  }

  .plan-features li {
    display: flex;
    align-items: flex-start;
    margin-bottom: 12px; /* Reducimos la separación entre los ticks (antes 16px) */
    font-size: 1rem;
    color: var(--deep-eggplant, #1a2530);
    line-height: 1.4;
  }

  .plan-features li i {
    color: var(--electric-violet, #8d37d4);
    margin-right: 12px;
    margin-top: 4px; /* Para que el check quede alineado si el texto ocupa dos líneas */
  }

  .btn-primary-precios {
    color: #fff;
    background-color: #7e57c2;
    border-radius: 8px;
    padding: 10px 25px;
    font-size: 1rem;
    font-weight: bold;
    text-decoration: none;
    border: 1px solid transparent;
    transition: all 0.3s;
    display: inline-block;
    box-shadow: 0 10px 25px #7e57c266;
  }

  .btn-primary-precios:hover {
    color: #7e57c2;
    background-color: #fcfbff;
    border: 1px solid #7e57c277;
    transform: translateY(-2px);
  }

  .btn-mockup-precios {
    height: 48px;
    border: 2px dashed var(--electric-violet);
    background-color: var(--white-iris);
    color: var(--dark-violet);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    font-weight: bold;
    text-decoration: none; /* ¡Esta es la magia que quita la línea! */
  }

  /* ==========================================
   ESCAPARATE DE DEMOS (CARRUSEL MÓVILES)
========================================== */
  .demos-section {
    background-color: #fcfbff;
    padding: 80px 0;
    overflow: hidden; /* Evita que el scroll horizontal rompa la web entera */
  }

  .section-header {
    text-align: center;
    margin-bottom: 30px;
  }

  .section-title-demos {
    text-align: center;
    font-size: 2.25rem;
    font-weight: bold;
    margin-bottom: 20px;
  }

  .section-subtitle {
    color: var(--slate-600, #4a5568);
    font-size: 1.2rem;
    max-width: 700px;
    margin: 0 auto;
    font-weight: 6 00;
  }

  .carousel-wrapper {
    position: relative;
    max-width: 1050px;
    margin: 0 auto;
    padding: 0; /* Dejamos hueco para las flechas */
  }

  /* La pista donde deslizan los elementos */
  .carousel-track {
    display: flex;
    gap: 40px;
    overflow-x: auto;
    scroll-snap-type: x mandatory; /* Fuerza a que el móvil se encaje en el centro al deslizar */
    scrollbar-width: none; /* Oculta la barra en Firefox */
    padding: 20px 40px 40px 40px;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
  }

  .carousel-track::-webkit-scrollbar {
    display: none; /* Oculta la barra en Chrome/Safari */
  }

  .carousel-item {
    scroll-snap-align: center; /* Punto de anclaje */
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* El diseño del falso iPhone */
  .phone-mockup {
    width: 200px;
    height: 400px;
    /* El bisel negro fino de la pantalla */
    border: 12px solid #000000;
    border-radius: 45px;
    position: relative;
    overflow: hidden;
    /* Magia 3D: El borde metálico exterior creado con sombras apiladas */
    box-shadow:
      0 0 0 2px #e2e8f0,
      /* Brillo metálico clarito */ 0 0 0 4px #94a3b8,
      /* Borde gris titanio */ 0 25px 50px rgba(26, 16, 45, 0.2); /* Sombra elegante proyectada */
    margin-bottom: 24px;
    background-color: #fff;
    transition: transform 0.4s ease;
  }

  .carousel-item:hover .phone-mockup {
    transform: translateY(-10px);
  }

  /* La "Isla Dinámica" (Dynamic Island) exclusiva de los iPhone modernos */
  .phone-notch {
    position: absolute;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    width: 65px;
    height: 20px;
    background-color: #000000;
    border-radius: 20px;
    z-index: 2;
    /* Detalle pro: Alineamos la cámara dentro de la isla */
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: 8px;
  }

  /* El detallito definitivo: El brillo de la lente de la cámara frontal */
  .phone-notch::after {
    content: "";
    width: 12px;
    height: 12px;
    background-color: #111;
    border-radius: 50%;
    box-shadow: inset -2px -2px 4px rgba(255, 255, 255, 0.15);
  }

  .phone-mockup img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .demo-title {
    font-family: "Montserrat", system-ui, sans-serif;
    background-color: #fcfbff;
    border: 1px solid #7e57c277;
    border-radius: 12px;
    margin-top: 10px;
    padding: 16px 15px;
    box-shadow: 0 10px 25px #7e57c266;
    font-size: 1.2rem;
    color: var(--dark-violet);
    margin-bottom: 30px;
  }

  .btn-link {
    color: #6b3fb8;
    background-color: #fcfbff;
    border: 1px solid #7e57c277;
    border-radius: 12px;
    margin-top: 10px;
    padding: 16px 15px;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s;
    display: inline-block;
    box-shadow: 0 10px 25px #7e57c266;
  }

  .btn-link:hover {
    color: #fff;
    background-color: #7e57c266;
    transform: translateY(-2px);
  }

  /* Flechas de navegación */
  .carousel-arrow {
    position: absolute;
    top: 40%;
    transform: translateY(-50%);
    background-color: rgba(
      255,
      255,
      255,
      0.6
    ); /* Fondo blanco semi-transparente */
    backdrop-filter: blur(
      4px
    ); /* Difumina lo que hay detrás del botón, queda súper premium */
    border: 1px solid rgba(255, 255, 255, 0.4);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
    color: var(--deep-eggplant, #1a2530);
    font-size: 1.2rem;
    transition: all 0.3s ease;
    z-index: 10;
  }

  .carousel-arrow:hover {
    background-color: var(--electric-violet, #8d37d4);
    color: var(--white, #fff);
    border-color: var(--electric-violet, #8d37d4);
  }

  .carousel-arrow.left {
    left: -75px;
  }
  .carousel-arrow.right {
    right: -75px;
  }

  /* ==========================================
     LEAD CAPTURE SECTION
  ========================================== */
  /* Sección Contenedor */
  .contacto-boda-section {
    padding: 80px 20px;
    background-color: var(--fondo-oscuro, #1a102d);
    color: white;
  }

  .text-center {
    text-align: left;
  }

  .section-main-title {
    font-size: 2.5rem; /* Tamaño grande y potente */
    color: white;
    margin-bottom: 50px; /* Separación para que no pegue con el calendario */
    font-family:
      "Montserrat", sans-serif; /* O la tipografía que estés usando */
    font-weight: 800;
    line-height: 1.2;
  }

  .contacto-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: start;
  }

  .cal-widget {
    width: 100%;
    height: 460px;
    background: rgba(255, 255, 255, 0.03);
    border: 2px solid rgba(166, 114, 255, 0.15);
