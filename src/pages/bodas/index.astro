  <script>
    window.addEventListener("DOMContentLoaded", () => {
      // 1. Lógica del desplegable según la URL
      const plan = new URLSearchParams(window.location.search).get("plan");
      if (plan) {
        const selectPlan = document.getElementById("plan-seleccionado");
        selectPlan.value = plan;
        if (selectPlan.value !== plan) {
          selectPlan.selectedIndex = 0;
        }
        const seccionContacto = document.getElementById("contacto");
        if (seccionContacto) {
          seccionContacto.scrollIntoView({ behavior: "smooth" });
        }
      }

      // 2. Lógica del Formulario
      const formBoda = document.getElementById("formulario-boda");

      // Verificamos que el formulario existe para evitar errores en consola
      if (formBoda) {
        formBoda.addEventListener("submit", function (e) {
          e.preventDefault();

          const btn = document.getElementById("btn-submit");
          btn.innerText = "Enviando...";
          btn.disabled = true;

          const data = {
            access_key: "1bc2d285-71cb-4fe3-806f-530066ab6e15",
            subject: "Nuevo Lead: Invitación Boda",
            nombre: document.getElementById("nombre").value,
            email: document.getElementById("email").value,
            fecha: document.getElementById("fecha").value,
            plan: document.getElementById("plan-seleccionado").value,
          };

          Promise.all([
            fetch("https://api.web3forms.com/submit", {
              method: "POST",
              headers: {
                "Content-Type": "application/json",
                Accept: "application/json",
              },
              body: JSON.stringify(data),
            }),
            fetch(
              "https://hook.eu1.make.com/mxvqg7gwne43yab165v2uhtyw5yh115r",
              {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data),
              },
            ),
          ])
            .then(async (results) => {
              const result = await results[0].json();
              if (result.success) {
                // 🔥 EVENTOS DE CONVERSIÓN PARA META, ANALYTICS Y CLARITY 🔥
                if (typeof gtag === "function")
                  gtag("event", "generate_lead", { currency: "EUR", value: 0 });
                if (typeof fbq === "function") fbq("track", "Lead");
                if (typeof clarity === "function")
                  clarity("set", "lead", "boda");

                alert("¡Solicitud recibida! Te contactaremos pronto.");
                formBoda.reset();
              } else {
                throw new Error("Error en el envío");
              }
            })
            .catch(() => {
              alert("Hubo un error. Por favor, inténtalo de nuevo.");
            })
            .finally(() => {
              btn.innerText = "Solicitar Presupuesto";
              btn.disabled = false;
            });
        });
      }
    });

    window.addEventListener("DOMContentLoaded", () => {
      const cookieBanner = document.getElementById("cookie-banner");
      const acceptBtn = document.getElementById("btn-accept-cookies");
      const declineBtn = document.getElementById("btn-decline-cookies");

      // 1. Comprobamos si el usuario ya ha tomado una decisión previamente
      const consent = localStorage.getItem("cookieConsent");

      if (!consent) {
        // Si no hay decisión, mostramos el banner.
        // Usamos "flex" porque tu CSS .cookie-card-uiverse usa display: flex
        cookieBanner.style.display = "flex";
      }

      // 2. Acción al Aceptar
      acceptBtn.addEventListener("click", () => {
        localStorage.setItem("cookieConsent", "accepted");
        cookieBanner.style.display = "none";

        // Activamos Google Analytics
        if (typeof gtag === "function") {
          gtag("consent", "update", {
            ad_storage: "granted",
            ad_user_data: "granted",
            ad_personalization: "granted",
            analytics_storage: "granted",
          });
        }

        // Activamos Microsoft Clarity
        if (typeof clarity === "function") {
          clarity("consent");
        }

        // Activamos Meta Pixel
        if (typeof fbq === "function") {
          fbq("consent", "grant");
        }
      });

      // 3. Acción al Rechazar
      declineBtn.addEventListener("click", () => {
        localStorage.setItem("cookieConsent", "declined");
        cookieBanner.style.display = "none";

        // Aseguramos que Google mantenga el rechazo
        if (typeof gtag === "function") {
          gtag("consent", "update", {
            ad_storage: "denied",
            ad_user_data: "denied",
            ad_personalization: "denied",
            analytics_storage: "denied",
          });
        }
      });
    });
  </script>
