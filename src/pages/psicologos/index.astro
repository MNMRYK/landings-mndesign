    margin: 0;
    font-size: 1.5rem;
  }
  .form-subtext {
    color: var(--white-iris);
    font-size: 1.1rem;
    margin-bottom: 10px;
  }

  .form-grupo label {
    display: block;
    font-weight: bold;
    margin-bottom: 8px;
    font-size: 1rem;
  }

  .form-grupo input,
  .form-grupo textarea {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid var(--border-color, #e2d8f5);
    border-radius: 12px;
    font-size: 1rem;
    font-family: inherit;
  }

  /* Botón y Notas */
  .btn-final-glow {
    color: #fcfbff;
    background-color: #8aa3b3;
    border: 1px solid #8aa3b3;
    border-radius: 8px;
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s;
    display: inline-block;
    box-shadow: 0 10px 25px #5e707188;
    transition: background 0.3s ease;
    font-family: "Nunito", system-ui, sans-serif;
  }

  .btn-final-glow:hover {
    color: #fcfbff;
    background-color: var(--text-muted);
    transform: translateY(-2px);
  }

  .privacy-note {
    text-align: center;
    font-size: 0.85rem;
    color: #888;
  }

  .formulario select {
    width: 100%;
    /* padding: arriba, derecha (mucho espacio), abajo, izquierda */
    padding: 12px 40px 12px 16px;
    border: 1px solid var(--border-color, #e2d8f5);
    border-radius: 12px; /* Unificado con los inputs de texto */
    background-color: var(--white);
    color: var(--text-primary);
    font-family: "Nunito", system-ui, sans-serif;
    cursor: pointer;
    font-size: 1rem;
    /* 1. Ocultamos la flecha fea por defecto de Chrome/Safari */
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;

    /* 2. Dibujamos una flecha minimalista directamente desde CSS */
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%238aa3b3' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 16px center; /* Separación perfecta desde la derecha */
    background-size: 16px; /* Tamaño del icono */
  }

  /* Pequeño ajuste por si alguien usa Internet Explorer (aunque ya casi nadie lo hace) */
  .formulario select::-ms-expand {
    display: none;
  }

