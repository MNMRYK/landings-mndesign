    padding: 80px 25px 40px;
  }

  .text-center {
    text-align: left;
  }

  .section-main-title {
    font-size: 2.5rem;
    color: var(--iris-glaze);
    margin-bottom: 50px; /* Separación para que no pegue con el calendario */
    font-family:
      "Montserrat", sans-serif; /* O la tipografía que estés usando */
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: 0.03em;
  }

  .contacto-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 60px;
    align-items: start;
  }

  .cal-widget {
    width: 100%;
    height: 460px;
    background: var(--psico-light);
    border: 2px solid rgba(166, 114, 255, 0.15);
    border-radius: 30px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
    position: relative;
  }

  /* Iframe limpio: sin escalas, sin transformaciones raras */
  .calendar-iframe {
    width: 125%; /* Esto compensa el 0.85 de escala (1 / 0.85 ≈ 1.176) */
    height: 570px; /* Altura mayor para que el contenido de Cal.com no se corte */
    border: none;
    display: block;
    transform: scale(0.8); /* ¡Aquí está la reducción! */
    transform-origin: top left;
  }

  .beneficios-lista {
    list-style: none;
    padding-top: 10px;
