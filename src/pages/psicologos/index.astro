  }

  .check-icon-circle {
    font-size: 1.4rem;
    margin-right: 10px;
    color: #7e57c2;
  }

  /* Estilo del Formulario */
  .formulario {
    border: 1px solid #5e707165;
    border-radius: 20px;
    background-color: var(--fondo-claro);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.185);
