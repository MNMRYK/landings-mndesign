  }

  .btn-primary {
    color: #fcfbff;
    background-color: #8aa3b3;
    border-radius: 8px;
    margin-top: 20px;
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    border: 1px solid transparent;
    transition: all 0.3s;
    display: inline-block;
    box-shadow: 0 10px 25px #5e7071;
  }

  .btn-primary:hover {
    color: #fcfbff;
    background-color: var(--text-muted);
    border: 1px solid #8aa3b3;
    transform: translateY(-2px);
  }

  .btn-secondary {
    color: var(--text-muted);
    background-color: #fcfbff;
    border: 1px solid #8aa3b3;
    border-radius: 8px;
    margin-top: 20px;
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.3s;
    display: inline-block;
    box-shadow: 0 10px 25px #5e7071;
  }

  .btn-secondary:hover {
    color: #fcfbff;
    background-color: var(--text-muted);
    border: 1px solid #8aa3b3;
    transform: translateY(-2px);
  }

  /* Contenedor padre de los visuals */
  .hero-visuals {
    position: relative;
    width: 100%;
    height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* El Mac (fondo) */
  .mac-mockup {
    position: absolute;
    left: -10px;
    width: 115%;
    z-index: 1;
    transition: transform 0.3s ease;
  }

  .mac-mockup img {
    width: 100%;
    height: auto;
    border-radius: 12px; /* Ajusta según tu imagen */
  }

  /* El iPhone (encima) */
  .mobile-mockup {
    position: absolute;
    bottom: 70px; /* Sale un poco por abajo del Mac */
    left: -40px; /* Desplazado a la derecha */
    width: 25%; /* Tamaño pequeño comparado con el Mac */
    z-index: 2;

    overflow: hidden;
    transition: transform 0.3s ease;
  }

  .mobile-mockup img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Efecto suave al pasar el ratón */
  .mac-mockup:hover {
    transform: scale(1.02);
  }
  .mobile-mockup:hover {
    transform: translateY(-10px);
  }

  /* ==========================================
     INTERACCIONES
  ========================================== */

  .features-section {
