  /* ==========================================
     HERO SECTION
  ========================================== */
  .hero-section {
    background-color: var(--fondo-claro);
    padding: 110px 0;
    overflow: hidden;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .tag {
    display: inline-block;
